{
  "name": "drawshare",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first collaborative whiteboard that streams your live writing to any screen over the local network.",
  "author": "Shravan Goswami",
  "license": "MIT",
  "homepage": "https://shravangoswami.com/DrawShare/",
  "repository": {
    "type": "git",
    "url": "https://github.com/shravanngoswamii/DrawShare.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "intro.js": "^8.3.2",
    "perfect-freehand": "^1.2.2",
    "pinia": "^2.2.4",
    "ulid": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitejs/plugin-vue": "^6.0.6",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vue-tsc": "^3.2.9"
  }
}
