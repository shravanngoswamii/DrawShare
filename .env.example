# Live sharing relay (optional).
# wss:// URL of the deployed Cloudflare relay (see relay/README.md).
# When unset, the live-session feature is hidden. This value is public — it
# ships in the client bundle — so it is a GitHub Actions variable, not a secret.
VITE_LIVE_RELAY_URL=wss://drawshare.<your-subdomain>.workers.dev
